{
  "name": "tools",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev": "concurrently \"npm run dev -w packages/renderer\" \"npm run dev -w packages/electron\"",
    "preview": "npm run preview -w packages/electron",
    "build": "npm run build -w packages/electron"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1"
  }
}
