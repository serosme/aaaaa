{
  "name": "aaaaa",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "npm run dev -w packages/renderer",
    "dev:electron": "npm run dev -w packages/electron",
    "build": "npm run build -w packages/shared && npm run build -w packages/renderer && npm run build -w packages/electron",
    "dist:win": "npm run dist:win -w packages/electron"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1"
  }
}
