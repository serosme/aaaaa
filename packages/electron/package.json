{
  "name": "electron",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm --prefix ../shared run build && tsc -p tsconfig.json && electron .",
    "build": "npm --prefix ../shared run build && tsc -p tsconfig.json",
    "dist:win": "npm run build && npm --prefix ../renderer run build && electron-builder --win"
  },
  "dependencies": {
    "@app/shared": "*"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "typescript": "^6.0.0"
  },
  "build": {
    "appId": "tools",
    "productName": "Tools",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer/dist"
      }
    ],
    "win": {
      "target": "zip"
    }
  }
}
