{
  "name": "electron",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && cross-env NODE_ENV=dev electron .",
    "preview": "npm --prefix ../renderer run build && tsc -p tsconfig.json && cross-env NODE_ENV=preview electron .",
    "build": "npm --prefix ../renderer run build && tsc -p tsconfig.json && electron-builder --win"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "shared": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "tools",
    "productName": "Tools",
    "directories": {
      "output": "release"
    },
    "electronLanguages": [
      "zh-CN"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "../renderer/.output",
        "to": "renderer/.output"
      }
    ],
    "win": {
      "target": "zip"
    }
  }
}
